<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - C.O.A. CV BUILDER</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/auth.css">
</head>
<body>
    <!-- HEADER / NAVBAR -->
    <header>
        <nav class="navbar">
            <div class="nav-container">
                <div class="logo-section">
                    <img src="/images/logo.png" alt="C.O.A. TECH Logo" class="logo">
                    <h1>C.O.A. CV BUILDER</h1>
                </div>
                <div class="nav-links">
                    <a href="/">Home</a>
                    <a href="/login">Login</a>
                    <a href="/signup">Sign Up</a>
                </div>
            </div>
        </nav>
    </header>

    <!-- FORGOT PASSWORD FORM -->
    <section class="auth-container">
        <div class="auth-box">
            <h2>Reset Your Password</h2>
            <p>Enter the email address you used to create your account.</p>

            <% if (error) { %>
                <div class="message error"><%= error %></div>
            <% } %>
            <% if (success) { %>
                <div class="message success"><%= success %></div>
            <% } %>

            <form action="/forgot-password" method="POST" class="auth-form">
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        placeholder="your@email.com"
                        required
                    >
                </div>

                <button type="submit" class="btn-submit">Find My Account</button>
            </form>

            <p class="auth-link">
                Remembered your password?
                <a href="/login">Back to login</a>
            </p>
        </div>
    </section>
</body>
</html>