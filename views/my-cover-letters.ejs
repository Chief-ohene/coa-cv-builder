<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Cover Letters - C.O.A. CV BUILDER</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/cv-builder.css">
</head>
<body>
    <!-- HEADER -->
    <header>
        <nav class="navbar">
            <div class="nav-container">
                <div class="logo-section">
                    <img src="/images/logo.png" alt="C.O.A. TECH Logo" class="logo">
                    <h1>C.O.A. CV BUILDER</h1>
                </div>
                <div class="nav-links">
                    <a href="/dashboard">Dashboard</a>
                    <a href="/cv/my-cvs">My CVs</a>
                    <a href="/auth/logout" class="btn-primary">Logout</a>
                </div>
            </div>
        </nav>
    </header>

    <section class="cv-list-container">
        <div class="cv-list-box">
            <h2>My Cover Letters</h2>
            <p class="cv-subtitle">
                Cover letters you have created for specific positions.
            </p>

            <% if (!letters || letters.length === 0) { %>
                <div class="cv-empty">
                    <p>You have not created any cover letters yet.</p>
                    <a href="/cv/my-cvs" class="btn-submit">Go to My CVs →</a>
                </div>
            <% } else { %>
                <div class="cv-list">
                    <% letters.forEach(function(letter) { %>
                        <div class="cv-card">
                            <div class="cv-card-header">
                                <div class="cv-card-title">
                                    <h3><%= letter.positionTitle || 'Cover Letter' %></h3>
                                    <p class="cv-card-role">
                                        <%= letter.companyName || '' %>
                                        <% if (letter.cv && (letter.cv.fullName || letter.cv.jobTitle)) { %>
                                            – for <%= letter.cv.fullName || '' %> (<%= letter.cv.jobTitle || '' %>)
                                        <% } %>
                                    </p>
                                </div>
                                <p class="cv-card-date">
                                    Created: <%= new Date(letter.createdAt).toLocaleDateString() %>
                                </p>
                            </div>
                            <div class="cv-card-actions">
                                <a href="/cover-letters/<%= letter._id %>" class="btn-small">View / PDF</a>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>
    </section>
</body>
</html>