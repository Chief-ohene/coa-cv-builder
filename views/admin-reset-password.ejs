<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin – Reset User Password - C.O.A. CV BUILDER</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/auth.css">
</head>
<body>
    <!-- HEADER -->
    <header class="dashboard-header">
        <nav class="navbar">
            <div class="nav-container">
                <div class="logo-section">
                    <img src="/images/logo.png" alt="C.O.A. TECH Logo" class="logo">
                    <h1>C.O.A. CV BUILDER - Admin</h1>
                </div>
                <div class="nav-links">
                    <span class="user-greeting">Admin: <%= admin.fullname %></span>
                    <a href="/admin">Admin Dashboard</a>
                    <a href="/dashboard">User Dashboard</a>
                    <a href="/auth/logout" class="btn-logout">Logout</a>
                </div>
            </div>
        </nav>
    </header>

    <!-- RESET FORM -->
    <section class="auth-container">
        <div class="auth-box">
            <h2>Reset User Password</h2>
            <p>Enter the user&#39;s email and the new password.</p>

            <% if (error) { %>
                <div class="message error"><%= error %></div>
            <% } %>
            <% if (success) { %>
                <div class="message success"><%= success %></div>
            <% } %>

            <form action="/admin/reset-password" method="POST" class="auth-form">
                <div class="form-group">
                    <label for="email">User Email Address</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        placeholder="user@example.com"
                        required
                    >
                </div>

                <div class="form-group">
                    <label for="newPassword">New Password</label>
                    <input 
                        type="password" 
                        id="newPassword" 
                        name="newPassword" 
                        placeholder="At least 6 characters"
                        required
                    >
                </div>

                <div class="form-group">
                    <label for="confirmPassword">Confirm New Password</label>
                    <input 
                        type="password" 
                        id="confirmPassword" 
                        name="confirmPassword" 
                        placeholder="Re-enter new password"
                        required
                    >
                </div>

                <button type="submit" class="btn-submit">Reset Password</button>
            </form>

            <p class="auth-link">
                Back to <a href="/admin">Admin Dashboard</a>
            </p>
        </div>
    </section>
</body>
</html>