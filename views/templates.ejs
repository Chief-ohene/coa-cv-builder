<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV Templates - C.O.A. CV BUILDER</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

    <!-- HEADER / NAVBAR -->
    <header class="dashboard-header">
        <nav class="navbar">
            <div class="nav-container">
                <div class="logo-section">
                    <img src="/images/logo.png" alt="C.O.A. TECH Logo" class="logo">
                    <h1>C.O.A. CV BUILDER</h1>
                </div>
                <div class="nav-links">
                    <a href="/">Home</a>
                    <a href="/dashboard">Dashboard</a>
                    <a href="/auth/logout" class="btn-logout">Logout</a>
                </div>
            </div>
        </nav>
    </header>

    <!-- MAIN CONTENT -->
    <main class="dashboard-main">
        <div class="dashboard-container">

            <section style="margin: 3rem 0;">
                <h2 style="color: #006B3F; font-size: 2rem; margin-bottom: 0.5rem;">
                    CV Templates
                </h2>

                <p style="color: #4b5563; margin-bottom: 1.5rem;">
                    C.O.A. CV BUILDER offers multiple professional layouts for your CV.
                    All users have access to our Professional Classic layout.
                    Premium users can also use our Modern layout when previewing and downloading CVs.
                </p>

                <div class="features-comparison">

                    <!-- CLASSIC TEMPLATE -->
                    <div class="feature-item">
                        <span class="check active">
                            Available (Free & Premium)
                        </span>
                        <span>
                            <strong>Professional Classic</strong> – clean, structured CV
                            suitable for most job applications. This is the default layout
                            used when you preview or download your CV.
                        </span>
                    </div>

                    <!-- MODERN TEMPLATE -->
                    <div class="feature-item">
                        <span class="check <%= (typeof user !== 'undefined' && user.isPremium) ? 'active' : 'inactive' %>">
                            <%= (typeof user !== 'undefined' && user.isPremium) ? 'Available (Premium)' : 'Premium Only' %>
                        </span>
                        <span>
                            <strong>Modern Layout</strong> – a two-column modern design
                            that highlights contact details and skills on the left,
                            with experience and education on the right.
                            <% if (!(typeof user !== 'undefined' && user.isPremium)) { %>
                                Upgrade to Premium to unlock this template.
                            <% } %>
                        </span>
                    </div>

                    <!-- FUTURE TEMPLATE -->
                    <div class="feature-item">
                        <span class="check inactive">
                            Coming Soon
                        </span>
                        <span>
                            <strong>Tech / Projects Layout</strong> – optimized for
                            software developers and technical roles, focusing on
                            projects, technologies, and certifications.
                        </span>
                    </div>

                </div>

                <p style="margin-top: 2rem; color: #6b7280;">
                    To switch templates for a CV:
                    Go to <strong>My CVs</strong> → Click <strong>View / PDF</strong> →
                    Choose your preferred template at the top of the preview screen.
                </p>

            </section>

        </div>
    </main>

</body>
</html>