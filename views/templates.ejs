<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV Templates - C.O.A. CV BUILDER</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
        .templates-wrapper {
            max-width: 1100px;
            margin: 60px auto;
            padding: 20px;
        }

        .templates-title {
            font-size: 26px;
            font-weight: 600;
            margin-bottom: 40px;
        }

        .templates-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 40px;
        }

        .template-card {
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.06);
            overflow: hidden;
            transition: 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        .template-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 32px rgba(0,0,0,0.1);
        }

        .template-preview {
            height: 200px;
            background: linear-gradient(135deg, #e5e7eb, #f3f4f6);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #9ca3af;
            font-weight: 600;
        }

        .template-body {
            padding: 25px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .template-name {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .template-description {
            font-size: 14px;
            color: #6b7280;
            margin-bottom: 20px;
            flex: 1;
        }

        .premium-tag {
            display: inline-block;
            font-size: 12px;
            background: #111;
            color: #fff;
            padding: 4px 12px;
            border-radius: 20px;
            margin-bottom: 10px;
        }

        .template-actions {
            margin-top: auto;
        }
    </style>
</head>
<body>

<header class="dashboard-header">
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo-section">
                <img src="/images/logo.png" alt="Logo" class="logo">
                <h1>C.O.A. CV BUILDER</h1>
            </div>
            <div class="nav-links">
                <a href="/dashboard">Dashboard</a>
                <a href="/cv/my-cvs">My CVs</a>
                <a href="/auth/logout" class="btn-logout">Logout</a>
            </div>
        </div>
    </nav>
</header>

<div class="templates-wrapper">

    <div class="templates-title">Choose a CV Template</div>

    <div class="templates-grid">

        <!-- Classic -->
        <div class="template-card">
            <div class="template-preview">
                Classic Preview
            </div>
            <div class="template-body">
                <div class="template-name">Professional 