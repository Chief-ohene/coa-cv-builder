<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV Templates - C.O.A. CV BUILDER</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

<header class="dashboard-header">
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo-section">
                <img src="/images/logo.png" alt="Logo" class="logo">
                <h1>C.O.A. CV BUILDER</h1>
            </div>
            <div class="nav-links">
                <a href="/dashboard">Dashboard</a>
                <a href="/cv/my-cvs">My CVs</a>
                <a href="/auth/logout" class="btn-logout">Logout</a>
            </div>
        </div>
    </nav>
</header>

<main class="dashboard-main">
    <div class="dashboard-container">

        <h2 style="margin-bottom: 30px;">Choose Your CV Template</h2>

        <div class="dashboard-cards">

            <!-- Classic -->
            <div class="dashboard-card">
                <h3>Professional Classic</h3>
                <p>
                    Clean and structured layout suitable for internships, NSS, and most job applications.
                </p>
                <a href="/cv/my-cvs" class="btn-primary">Use Classic</a>
            </div>

            <!-- Modern -->
            <div class="dashboard-card">
                <h3>Modern Layout</h3>
                <p>
                    Two-column design ideal for tech, creative, and modern corporate roles.
                </p>

                <% if (user.isPremium) { %>
                    <a href="/cv/my-cvs" class="btn-primary">Use Modern</a>
                <% } else { %>
                    <span class="premium-badge">Premium</span>
                    <a href="/upgrade" class="btn-secondary">Upgrade to Use</a>
                <% } %>
            </div>

            <!-- Compact -->
            <div class="dashboard-card">
                <h3>Compact Professional</h3>
                <p>
                    Single-column tight layout best for banking, consulting, and executive roles.
                </p>

                <% if (user.isPremium) { %>
                    <a href="/cv/my-cvs" class="btn-primary">Use Compact</a>
                <% } else { %>
                    <span class="premium-badge">Premium</span>
                    <a href="/upgrade" class="btn-secondary">Upgrade to Use</a>
                <% } %>
            </div>

        </div>

    </div>
</main>

</body>
</html>