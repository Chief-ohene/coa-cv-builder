<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV Templates - C.O.A. CV BUILDER</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
        .templates-wrapper {
            max-width: 1200px;
            margin: 50px auto;
            padding: 20px;
        }

        .templates-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 40px;
        }

        .template-card-pro {
            background: #ffffff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 24px rgba(0,0,0,0.06);
            transition: 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        .template-card-pro:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 32px rgba(0,0,0,0.1);
        }

        .template-preview {
            height: 220px;
            background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: #9ca3af;
            font-size: 18px;
        }

        .template-body {
            padding: 25px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .template-title {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .template-desc {
            font-size: 14px;
            color: #6b7280;
            margin-bottom: 20px;
            flex: 1;
        }

        .template-footer {
            margin-top: auto;
        }

        .premium-tag {
            display: inline-block;
            font-size: 12px;
            background: #111;
            color: #fff;
            padding: 4px 10px;
            border-radius: 20px;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>

<header class="dashboard-header">
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo-section">
                <img src="/images/logo.png" alt="Logo" class="logo">
                <h1>C.O.A. CV BUILDER</h1>
            </div>
            <div class="nav-links">
                <a href="/dashboard">Dashboard</a>
                <a href="/cv/my-cvs">My CVs</a>
                <a href="/auth/logout" class="btn-logout">Logout</a>
            </div>
        </div>
    </nav>
</header>

<div class="templates-wrapper">

    <h2 style="margin-bottom:40px;">Choose a CV Template</h2>

    <div class="templates-grid">

        <!-- Classic -->
        <div class="template-card-pro">
            <div class="template-preview">
                Classic Preview
            </div>
            <div class="template-body">
                <div class="template-title">Professional Classic</div>
                <div class="template-desc">
                    Clean, structured layout suitable for most internships, NSS placements and job applications.
                </div>
                <div class="template-footer">
                    <a href="/cv/my-cvs" class="btn-primary">Use Template</a>
                </div>
            </div>
        </div>

        <!-- Modern -->
        <div class="template-card-pro">
            <div class="template-preview">
                Modern Preview
            </div>
            <div class="template-body">
                <div class="template-title">Modern Layout</div>
                <div 