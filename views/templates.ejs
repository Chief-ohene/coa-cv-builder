<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV Templates - C.O.A. CV BUILDER</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .templates-container {
            max-width: 1100px;
            margin: 40px auto;
            padding: 20px;
        }

        .templates-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }

        .template-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 6px 16px rgba(0,0,0,0.08);
            padding: 20px;
            text-align: center;
            transition: 0.3s ease;
        }

        .template-card:hover {
            transform: translateY(-5px);
        }

        .template-title {
            font-size: 20px;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .template-desc {
            font-size: 14px;
            color: #555;
            margin-bottom: 15px;
        }

        .template-badge {
            display: inline-block;
            background: #111;
            color: #fff;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            margin-bottom: 10px;
        }

        .template-btn {
            display: inline-block;
            margin-top: 10px;
            padding: 10px 20px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: bold;
        }

        .btn-free {
            background: #4CAF50;
            color: #fff;
        }

        .btn-premium {
            background: #000;
            color: #fff;
        }

        .locked {
            background: #ccc;
            color: #444;
            cursor: not-allowed;
        }
    </style>
</head>
<body>

<div class="templates-container">
    <h2 style="text-align:center; margin-bottom:30px;">Choose Your CV Template</h2>

    <div class="templates-grid">

        <!-- Classic -->
        <div class="template-card">
            <div class="template-title">Professional Classic</div>
            <div class="template-desc">
                Clean and structured layout suitable for most internships, NSS, and job applications.
            </div>
            <a href="/cv/my-cvs" class="template-btn btn-free">Use Classic</a>
        </div>

        <!-- Modern -->
        <div class="template-card">
            <div class="template-title">Modern Layout</div>
            <div class="template-desc">
                Two-column layout ideal for creative, tech, and modern corporate roles.
            </div>

            <% if (user.isPremium) { %>
                <a href="/cv/my-cvs" class="template-btn btn-premium">Use Modern</a>
            <% } else { %>
                <div class="template-badge">Premium</div>
                <a href="/upgrade" class="template-btn btn-premium">Upgrade to Use</a>
            <% } %>
        </div>

        <!-- Compact -->
        <div class="template-card">
            <div class="template-title">Compact Professional</div>
            <div class="template-desc">
                Tight single-column layout best for corporate, banking, and consulting roles.
            </div>

            <% if (user.isPremium) { %>
                <a href="/cv/my-cvs" class="template-btn btn-premium">Use Compact</a>
            <% } else { %>
                <div class="template-badge">Premium</div>
                <a href="/upgrade" class="template-btn btn-premium">Upgrade to Use</a>
            <% } %>
        </div>

    </div>
</div>

</body>
</html>