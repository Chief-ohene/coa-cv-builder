<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CV Templates - C.O.A. CV BUILDER</title>

<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/dashboard.css">

<style>
.templates-wrapper {
    max-width: 1100px;
    margin: 60px auto;
    padding: 20px;
}

.templates-title {
    font-size: 26px;
    font-weight: 600;
    margin-bottom: 40px;
}

.templates-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 40px;
}

.template-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    overflow: hidden;
    transition: 0.3s ease;
    display: flex;
    flex-direction: column;
}

.template-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.1);
}

.template-preview {
    height: 220px;
    background: #f3f4f6;
    display: flex;
    align-items: center;
    justify-content: center;
}

.template-body {
    padding: 25px;
    flex: 1;
    display: flex;
    flex-direction: column;
}

.template-name {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 10px;
}

.template-description {
    font-size: 14px;
    color: #6b7280;
    margin-bottom: 20px;
    flex: 1;
}

.premium-tag {
    display: inline-block;
    font-size: 12px;
    background: #111;
    color: #fff;
    padding: 4px 12px;
    border-radius: 20px;
    margin-bottom: 10px;
}

.template-actions {
    margin-top: auto;
}
</style>
</head>

<body>

<header class="dashboard-header">
<nav class="navbar">
<div class="nav-container">
<div class="logo-section">
<img src="/images/logo.png" alt="Logo" class="logo">
<h1>C.O.A. CV BUILDER</h1>
</div>
<div class="nav-links">
<a href="/dashboard">Dashboard</a>
<a href="/cv/my-cvs">My CVs</a>
<a href="/auth/logout" class="btn-logout">Logout</a>
</div>
</div>
</nav>
</header>

<div class="templates-wrapper">

<div class="templates-title">Choose a CV Template</div>

<div class="templates-grid">

<!-- CLASSIC -->
<div class="template-card">
<div class="template-preview">
<div style="width:85%; background:#fff; padding:15px; transform:scale(0.85); transform-origin:top;">
<h4 style="font-size:14px; font-weight:bold;">John Doe</h4>
<p style="font-size:10px;">john@email.com | 0240000000 | Accra</p>
<hr style="margin:6px 0;">
<p style="font-size:10px; font-weight:bold;">Professional Summary</p>
<p style="font-size:9px;">Results-driven professional with strong experience...</p>
</div>
</div>

<div class="template-body">
<div class="template-name">Professional Classic</div>
<div class="template-description">
Clean and structured layout suitable for internships, NSS placements and most job applications.
</div>
<div class="template-actions">
<a href="/cv/my-cvs" class="btn-primary">Use Template</a>
</div>
</div>
</div>

<!-- MODERN -->
<div class="template-card">
<div class="template-preview">
<div style="display:flex; width:85%; background:#fff; transform:scale(0.85); transform-origin:top;">
<div style="width:30%; background:#111; color:#fff; padding:12px;">
<p style="font-size:9px;">John Doe</p>
<p style="font-size:8px;">Skills</p>
</div>
<div style="width:70%; padding:12px;">
<p style="font-size:10px; font-weight:bold;">Experience</p>
<p style="font-size:9px;">Software Developer</p>
</div>
</div>
</div>

<div class="template-body">
<div class="template-name">Modern Layout</div>
<div class="template-description">
Two-column modern layout ideal for tech, creative and forward-thinking corporate roles.
</div>

<div class="template-actions">
<% if (user && user.isPremium) { %>
<a href="/cv/my-cvs" class="btn-primary">Use Template</a>
<% } else { %>
<div class="premium-tag">Premium</div>
<a href="/upgrade" class="btn-secondary">Upgrade to Use</a>
<% } %>
</div>
</div>
</div>

<!-- COMPACT -->
<div class="template-card">
<div class="template-preview">
<div style="width:85%; background:#fff; padding:12px; transform:scale(0.85); transform-origin:top;">
<p style="font-size:10px; font-weight:bold;">John Doe</p>
<p style="font-size:8px;">Corporate focused summary...</p>
<hr style="margin:5px 0;">
<p style="font-size:9px; font-weight:bold;">Experience</p>
<p style="font-size:8px;">Senior Analyst</p>
</div>
</div>

<div class="template-body">
<div class="template-name">Compact Professional</div>
<div class="template-description">
Single-column tight layout best for banking, consulting and executive-level roles.
</div>

<div class="template-actions">
<% if (user && user.isPremium) { %>
<a href="/cv/my-cvs" class="btn-primary">Use Template</a>
<% } else { %>
<div class="premium-tag">Premium</div>
<a href="/upgrade" class="btn-secondary">Upgrade to Use</a>
<% } %>
</div>
</div>
</div>

</div>
</div>

</body>
</html>