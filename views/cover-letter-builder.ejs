<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Cover Letter - C.O.A. CV BUILDER</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/auth.css">
    <link rel="stylesheet" href="/css/cv-builder.css">
</head>
<body>
    <!-- HEADER -->
    <header>
        <nav class="navbar">
            <div class="nav-container">
                <div class="logo-section">
                    <img src="/images/logo.png" alt="C.O.A. TECH Logo" class="logo">
                    <h1>C.O.A. CV BUILDER</h1>
                </div>
                <div class="nav-links">
                    <a href="/dashboard">Dashboard</a>
                    <a href="/cv/my-cvs">My CVs</a>
                    <a href="/auth/logout" class="btn-primary">Logout</a>
                </div>
            </div>
        </nav>
    </header>

    <section class="cv-builder-container">
        <div class="cv-builder-box">
            <h2>Create Cover Letter</h2>
            <p class="cv-subtitle">
                Based on CV: <strong><%= cv.fullName || '' %></strong> – <%= cv.jobTitle || '' %>
            </p>

            <% if (error) { %>
                <div class="message error"><%= error %></div>
            <% } %>

            <form action="/cover-letters/new/<%= cv._id %>" method="POST" class="cv-form">
                <h3>Position & Company</h3>
                <div class="cv-grid">
                    <div class="form-group">
                        <label for="companyName">Company Name</label>
                        <input
                            type="text"
                            id="companyName"
                            name="companyName"
                            placeholder="e.g. MTN Ghana"
                            required
                        >
                    </div>

                    <div class="form-group">
                        <label for="positionTitle">Position / Role</label>
                        <input
                            type="text"
                            id="positionTitle"
                            name="positionTitle"
                            placeholder="e.g. Senior Software Engineer"
                            required
                        >
                    </div>
                </div>

                <h3>Cover Letter Body</h3>
                <div class="form-group">
                    <textarea
                        id="body"
                        name="body"
                        rows="12"
                        placeholder="Dear Hiring Manager,

I am writing to apply for the [Position Title] role at [Company Name]. With my background as [your professional title from the CV], I believe I can add value to your team by...

[Describe your relevant experience, key achievements, and why you are a good fit.]

Thank you for considering my application.

Sincerely,
<%= cv.fullName || '' %>"
                        required
                    ></textarea>
                </div>

                <div class="cv-actions">
                    <a href="/cv/my-cvs" class="btn-secondary">Cancel</a>
                    <button type="submit" class="btn-submit">Save Cover Letter</button>
                </div>
            </form>
        </div>
    </section>
</body>
</html>