<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit CV - C.O.A. CV BUILDER</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/auth.css">
    <link rel="stylesheet" href="/css/cv-builder.css">
</head>
<body>
    <!-- HEADER -->
    <header>
        <nav class="navbar">
            <div class="nav-container">
                <div class="logo-section">
                    <img src="/images/logo.png" alt="C.O.A. TECH Logo" class="logo">
                    <h1>C.O.A. CV BUILDER</h1>
                </div>
                <div class="nav-links">
                    <a href="/dashboard">Dashboard</a>
                    <a href="/auth/logout" class="btn-primary">Logout</a>
                </div>
            </div>
        </nav>
    </header>

    <section class="cv-builder-container">
        <div class="cv-builder-box">
            <h2>Edit CV</h2>
            <p class="cv-subtitle">Update your CV details below. Changes will be saved immediately.</p>

            <% if (error) { %>
                <div class="message error"><%= error %></div>
            <% } %>

            <form action="/cv/<%= cv._id %>/edit" method="POST" class="cv-form">
                <h3>Personal Information</h3>
                <div class="cv-grid">
                    <div class="form-group">
                        <label for="fullName">Full Name</label>
                        <input
                            type="text"
                            id="fullName"
                            name="fullName"
                            value="<%= cv.fullName || '' %>"
                            required
                        >
                    </div>

                    <div class="form-group">
                        <label for="jobTitle">Professional Title</label>
                        <input
                            type="text"
                            id="jobTitle"
                            name="jobTitle"
                            value="<%= cv.jobTitle || '' %>"
                            placeholder="e.g. Software Developer, Accountant"
                            required
                        >
                    </div>

                    <div class="form-group">
                        <label for="email">Email</label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            value="<%= cv.email || user.email %>"
                            required
                        >
                    </div>

                    <div class="form-group">
                        <label for="phone">Phone</label>
                        <input
                            type="tel"
                            id="phone"
                            name="phone"
                            value="<%= cv.phone || user.phone %>"
                            required
                        >
                    </div>

                    <div class="form-group full-width">
                        <label for="location">Location</label>
                        <input
                            type="text"
                            id="location"
                            name="location"
                            value="<%= cv.location || '' %>"
                            placeholder="e.g. Accra, Ghana"
                        >
                    </div>
                </div>

                <h3>Professional Summary</h3>
                <div class="form-group">
                    <textarea
                        id="summary"
                        name="summary"
                        rows="4"
                        placeholder="2–4 sentences summarising your experience, key strengths, and goals."
                    ><%= cv.summary || '' %></textarea>
                </div>

                <h3>Education</h3>
                <div class="cv-grid">
                    <div class="form-group">
                        <label for="eduSchool">School / Institution</label>
                        <input
                            type="text"
                            id="eduSchool"
                            name="eduSchool"
                            value="<%= cv.education && cv.education.school ? cv.education.school : '' %>"
                            placeholder="e.g. University of Ghana"
                        >
                    </div>

                    <div class="form-group">
                        <label for="eduDegree">Degree / Qualification</label>
                        <input
                            type="text"
                            id="eduDegree"
                            name="eduDegree"
                            value="<%= cv.education && cv.education.degree ? cv.education.degree : '' %>"
                            placeholder="e.g. BSc Computer Science"
                        >
                    </div>

                    <div class="form-group">
                        <label for="eduLocation">Location</label>
                        <input
                            type="text"
                            id="eduLocation"
                            name="eduLocation"
                            value="<%= cv.education && cv.education.location ? cv.education.location : '' %>"
                            placeholder="e.g. Legon, Accra"
                        >
                    </div>

                    <div class="form-group">
                        <label for="eduStartYear">Start Year</label>
                        <input
                            type="text"
                            id="eduStartYear"
                            name="eduStartYear"
                            value="<%= cv.education && cv.education.startYear ? cv.education.startYear : '' %>"
                            placeholder="e.g. 2018"
                        >
                    </div>

                    <div class="form-group">
                        <label for="eduEndYear">End Year</label>
                        <input
                            type="text"
                            id="eduEndYear"
                            name="eduEndYear"
                            value="<%= cv.education && cv.education.endYear ? cv.education.endYear : '' %>"
                            placeholder="e.g. 2022 or Present"
                        >
                    </div>

                    <div class="form-group full-width">
                        <label for="eduDetails">Details / Achievements</label>
                        <textarea
                            id="eduDetails"
                            name="eduDetails"
                            rows="3"
                            placeholder="Mention key courses, GPA (if strong), leadership roles, awards, etc."
                        ><%= cv.education && cv.education.details ? cv.education.details : '' %></textarea>
                    </div>
                </div>

                <h3>Work Experience</h3>
                <div class="cv-grid">
                    <div class="form-group">
                        <label for="expCompany">Company</label>
                        <input
                            type="text"
                            id="expCompany"
                            name="expCompany"
                            value="<%= cv.experience && cv.experience.company ? cv.experience.company : '' %>"
                            placeholder="e.g. C.O.A. TECH"
                        >
                    </div>

                    <div class="form-group">
                        <label for="expRole">Job Title</label>
                        <input
                            type="text"
                            id="expRole"
                            name="expRole"
                            value="<%= cv.experience && cv.experience.role ? cv.experience.role : '' %>"
                            placeholder="e.g. Software Developer"
                        >
                    </div>

                    <div class="form-group">
                        <label for="expLocation">Location</label>
                        <input
                            type="text"
                            id="expLocation"
                            name="expLocation"
                            value="<%= cv.experience && cv.experience.location ? cv.experience.location : '' %>"
                            placeholder="e.g. Accra, Ghana"
                        >
                    </div>

                    <div class="form-group">
                        <label for="expStartYear">Start Year</label>
                        <input
                            type="text"
                            id="expStartYear"
                            name="expStartYear"
                            value="<%= cv.experience && cv.experience.startYear ? cv.experience.startYear : '' %>"
                            placeholder="e.g. 2022"
                        >
                    </div>

                    <div class="form-group">
                        <label for="expEndYear">End Year</label>
                        <input
                            type="text"
                            id="expEndYear"
                            name="expEndYear"
                            value="<%= cv.experience && cv.experience.endYear ? cv.experience.endYear : '' %>"
                            placeholder="e.g. 2024 or Present"
                        >
                    </div>

                    <div class="form-group full-width">
                        <label for="expDetails">Responsibilities / Achievements</label>
                        <textarea
                            id="expDetails"
                            name="expDetails"
                            rows="4"
                            placeholder="Use bullet-style lines describing what you did and achieved."
                        ><%= cv.experience && cv.experience.details ? cv.experience.details : '' %></textarea>
                    </div>
                </div>

                <h3>Skills</h3>
                <div class="form-group">
                    <textarea
                        id="skills"
                        name="skills"
                        rows="4"
                        placeholder="List your key skills, separated by commas or on separate lines."
                    ><%= cv.skills || '' %></textarea>
                </div>

                <div class="cv-actions">
                    <a href="/cv/my-cvs" class="btn-secondary">Cancel</a>
                    <button type="submit" class="btn-submit">Save Changes</button>
                </div>
            </form>
        </div>
    </section>
</body>
</html>