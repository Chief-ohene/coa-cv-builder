<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= cv.fullName || 'CV Preview' %> - C.O.A. CV BUILDER</title>

<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/cv-preview.css">

<style>
.btn-download {
    background: #00c853;
    color: #ffffff;
    padding: 12px 28px;
    border: none;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
}

.btn-download:hover {
    background: #00b94a;
    transform: translateY(-2px);
}
</style>
</head>

<body>

<header>
<nav class="navbar">
<div class="nav-container">
<div class="logo-section">
<img src="/images/logo.png" alt="Logo" class="logo">
<h1>C.O.A. CV BUILDER</h1>
</div>
<div class="nav-links">
<a href="/dashboard">Dashboard</a>
<a href="/cv/my-cvs">My CVs</a>
<a href="/auth/logout" class="btn-primary">Logout</a>
</div>
</div>
</nav>
</header>

<section class="cv-preview-toolbar">
<div class="toolbar-inner">
<a href="/cv/my-cvs" class="btn-secondary">← Back to My CVs</a>

<div style="display: flex; gap: 1rem; align-items: center;">
<span style="font-size: 0.9rem; color: #6b7280;">
Viewing: <strong>Classic Template</strong>
</span>

<button type="button" class="btn-download" onclick="window.print()">
Download PDF
</button>
</div>

</div>
</section>

<main class="cv-preview-main">
<div class="resume-wrapper">

<section class="resume-header">
<h1 class="resume-name"><%= cv.fullName || '' %></h1>
<p class="resume-title"><%= cv.jobTitle || '' %></p>
<div class="resume-contact">
<% if (cv.location) { %>
<span><%= cv.location %></span>
<% } %>
<% if (cv.email) { %>
<span><%= cv.email %></span>
<% } %>
<% if (cv.phone) { %>
<span><%= cv.phone %></span>
<% } %>
</div>
</section>

<% if (cv.summary) { %>
<section class="resume-section">
<h2 class="section-title">Professional Summary</h2>
<div class="section-content">
<p><%= cv.summary %></p>
</div>
</section>
<% } %>

<% if (cv.experience && (cv.experience.company || cv.experience.details)) { %>
<section class="resume-section">
<h2 class="section-title">Work Experience</h2>
<div class="section-content">
<% if (cv.experience.company || cv.experience.role) { %>
<p>
<strong><%= cv.experience.role || '' %></strong>
<% if (cv.experience.company) { %>
– <%= cv.experience.company %>
<% } %>
</p>
<% } %>
<% if (cv.experience.location || cv.experience.startYear || cv.experience.endYear) { %>
<p>
<% if (cv.experience.location) { %>
<%= cv.experience.location %> •
<% } %>
<%= 