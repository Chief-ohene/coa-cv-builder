<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= cv.fullName %> - CV Preview</title>

<link rel="stylesheet" href="/css/style.css">

<style>
body {
    background: #f3f4f6;
    font-family: 'Segoe UI', Arial, sans-serif;
}

.preview-wrapper {
    max-width: 800px;
    margin: 60px auto;
    background: #ffffff;
    padding: 60px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
}

.preview-header {
    text-align: center;
    margin-bottom: 40px;
}

.preview-header h1 {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 8px;
}

.preview-contact {
    font-size: 14px;
    color: #555;
}

.preview-section {
    margin-bottom: 30px;
}

.preview-section h2 {
    font-size: 16px;
    text-transform: uppercase;
    border-bottom: 2px solid #00c853;
    padding-bottom: 6px;
    margin-bottom: 12px;
    letter-spacing: 0.5px;
}

.preview-section p {
    font-size: 14px;
    line-height: 1.6;
    color: #333;
}

.toolbar {
    max-width: 800px;
    margin: 30px auto 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.btn-download {
    background: #00c853;
    color: #ffffff;
    padding: 12px 28px;
    border-radius: 8px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: 0.3s ease;
}

.btn-download:hover {
    background: #00b94a;
    transform: translateY(-2px);
}
.btn-back {
    background: #fff7e6;        /* Soft warm background */
    color: #d97706;             /* Rich amber text */
    padding: 12px 24px;
    border-radius: 10px;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid #fbbf24;
    transition: all 0.3s ease;
}

.btn-back:hover {
    background: #fbbf24;
    color: #ffffff;
    transform: translateY(-2px);
}
@media print {
    body {
        background: #ffffff;
    }
    .toolbar {
        display: none;
    }
    .preview-wrapper {
        box-shadow: none;
        margin: 0;
        padding: 0;
    }
}
</style>
</head>

<body>

<div class="toolbar">
<a href="/cv/my-cvs" class="btn-back">← Back to My CVs</a>
<button class="btn-download" onclick="window.print()">Download PDF</button>
</div>

<div class="preview-wrapper">

<div class="preview-header">
<h1><%= cv.fullName %></h1>
<div class="preview-contact">
<%= cv.email %> | <%= cv.phone %> | <%= cv.location %>
</div>
</div>

<% if (cv.summary) { %>
<div class="preview-section">
<h2>Professional Summary</h2>
<p><%= cv.summary %></p>
</div>
<% } %>

<% if (cv.experience && cv.experience.company) { %>
<div class="preview-section">
<h2>Work Experience</h2>
<p><strong><%= cv.experience.role %></strong> – <%= cv.experience.company %></p>
<p><%= cv.experience.startYear %> - <%= cv.experience.endYear %></p>
<p><%= cv.experience.details %></p>
</div>
<% } %>

<% if (cv.education && cv.education.school) { %>
<div class="preview-section">
<h2>Education</h2>
<p><strong><%= cv.education.degree %></strong> – <%= cv.education.school %></p>
<p><%= cv.education.startYear %> - <%= cv.education.endYear %></p>
<p><%= cv.education.details %></p>
</div>
<% } %>

<% if (cv.skills) { %>
<div class="preview-section">
<h2>Skills</h2>
<p><%= cv.skills %></p>
</div>
<% } %>

</div>

</body>
</html>