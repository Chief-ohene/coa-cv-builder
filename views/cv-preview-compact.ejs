<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title><%= cv.fullName %> - Compact Corporate</title>

<style>
body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    color: #000;
}

.toolbar {
    max-width: 820px;
    margin: 25px auto 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.btn-download {
    background: #00c853;
    color: #ffffff;
    padding: 10px 24px;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
}

.btn-back {
    background: #fff7e6;
    color: #d97706;
    padding: 10px 20px;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid #fbbf24;
}

.compact-wrapper {
    max-width: 820px;
    margin: 40px auto;
    padding: 40px;
}

.compact-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 25px;
}

.compact-name {
    font-size: 22px;
    font-weight: 700;
}

.compact-contact {
    font-size: 12px;
    text-align: right;
}

.compact-section {
    margin-bottom: 18px;
    padding-left: 12px;
    border-left: 3px solid #000;
}

.compact-section h3 {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 6px;
    letter-spacing: 0.5px;
}

.compact-section p {
    font-size: 13px;
    line-height: 1.4;
}

.compact-dates {
    float: right;
    font-size: 12px;
}

.clear { clear: both; }

@media print {
    .toolbar { display: none; }
}
</style>
</head>

<body>

<div class="toolbar">
<a href="/cv/my-cvs" class="btn-back">← Back to My CVs</a>
<button class="btn-download" onclick="window.print()">Download PDF</button>
</div>

<div class="compact-wrapper">

<div class="compact-header">
<div class="compact-name"><%= cv.fullName %></div>
<div class="compact-contact">
<%= cv.email %><br>
<%= cv.phone %><br>
<%= cv.location %>
</div>
</div>

<% if (cv.summary) { %>
<div class="compact-section">
<h3>Professional Summary</h3>
<p><%= cv.summary %></p>
</div>
<% } %>

<% if (cv.experience && cv.experience.company) { %>
<div class="compact-section">
<h3>Experience</h3>
<p>
<strong><%= cv.experience.role %></strong> – <%= cv.experience.company %>
<span class="compact-dates">
<%= cv.experience.startYear %> - <%= cv.experience.endYear %>
</span>
</p>
<div class="clear"></div>
<p><%= cv.experience.details %></p>
</div>
<% } %>

<% if (cv.education && cv.education.school) { %>
<div class="compact-section">
<h3>Education</h3>
<p>
<strong><%= cv.education.degree %></strong> – <%= cv.education.school %>
<span class="compact-dates">
<%= cv.education.startYear %> - <%= cv.education.endYear %>
</span>
</p>
<div class="clear"></div>
<p><%= cv.education.details %></p>
</div>
<% } %>

<% if (cv.skills) { %>
<div class="compact-section">
<h3>Skills</h3>
<p><%= cv.skills %></p>
</div>
<% } %>

</div>

</body>
</html>