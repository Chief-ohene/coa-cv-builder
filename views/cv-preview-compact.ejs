<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Compact Template</title>
</head>
<body>

<h1><%= cv.fullName %></h1>
<p><%= cv.email %> | <%= cv.phone %> | <%= cv.location %></p>

<% if (cv.summary) { %>
<h2>Summary</h2>
<p><%= cv.summary %></p>
<% } %>

<% if (cv.experience && cv.experience.company) { %>
<h2>Experience</h2>
<p><strong><%= cv.experience.role %></strong> – <%= cv.experience.company %></p>
<p><%= cv.experience.details %></p>
<% } %>

<% if (cv.education && cv.education.school) { %>
<h2>Education</h2>
<p><strong><%= cv.education.degree %></strong> – <%= cv.education.school %></p>
<p><%= cv.education.details %></p>
<% } %>

<% if (cv.skills) { %>
<h2>Skills</h2>
<p><%= cv.skills %></p>
<% } %>

<button onclick="window.print()">Download PDF</button>

</body>
</html>