<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title><%= cv.fullName %> - Minimal</title>

<style>
body {
    background: #ffffff;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    color: #111;
}

.toolbar {
    max-width: 900px;
    margin: 30px auto 0;
    display: flex;
    justify-content: space-between;
}

.btn-download {
    background: #00c853;
    color: #fff;
    padding: 10px 22px;
    border-radius: 6px;
    border: none;
    font-weight: 600;
    cursor: pointer;
}

.btn-back {
    background: #fff7e6;
    color: #d97706;
    padding: 10px 18px;
    border-radius: 6px;
    text-decoration: none;
    border: 1px solid #fbbf24;
    font-weight: 600;
}

.wrapper {
    max-width: 900px;
    margin: 70px auto;
    padding: 0 40px;
}

.name {
    font-size: 36px;
    font-weight: 700;
    margin-bottom: 6px;
}

.contact {
    font-size: 14px;
    color: #666;
    margin-bottom: 50px;
}

.section {
    margin-bottom: 45px;
}

.section h3 {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 15px;
}

.section p {
    font-size: 15px;
    line-height: 1.8;
}

@media print {
    .toolbar { display: none; }
}
</style>
</head>

<body>

<div class="toolbar">
<a href="/cv/my-cvs" class="btn-back">← Back</a>
<button class="btn-download" onclick="window.print()">Download PDF</button>
</div>

<div class="wrapper">

<div class="name"><%= cv.fullName %></div>
<div class="contact">
<%= cv.email %> | <%= cv.phone %> | <%= cv.location %>
</div>

<% if (cv.summary) { %>
<div class="section">
<h3>Summary</h3>
<p><%= cv.summary %></p>
</div>
<% } %>

<% if (cv.experience && cv.experience.company) { %>
<div class="section">
<h3>Experience</h3>
<p>
<strong><%= cv.experience.role %></strong> – <%= cv.experience.company %><br>
<%= cv.experience.startYear %> - <%= cv.experience.endYear %><br><br>
<%= cv.experience.details %>
</p>
</div>
<% } %>

<% if (cv.education && cv.education.school) { %>
<div class="section">
<h3>Education</h3>
<p>
<strong><%= cv.education.degree %></strong> – <%= cv.education.school %><br>
<%= cv.education.startYear %> - <%= cv.education.endYear %><br><br>
<%= cv.education.details %>
</p>
</div>
<% } %>

<% if (cv.skills) { %>
<div class="section">
<h3>Skills</h3>
<p><%= cv.skills %></p>
</div>
<% } %>

</div>

</body>
</html>